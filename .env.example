# OpenAI-compatible LLM endpoint (provider-agnostic).
# DeepSeek example shown; swap baseUrl/key/model for OpenAI / 智谱 / local, etc.
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=deepseek-chat

# Shortcut: if none of LLM_BASE_URL/LLM_API_KEY/LLM_MODEL are set but
# DEEPSEEK_API_KEY is, the loader falls back to DeepSeek
# (baseUrl https://api.deepseek.com, model deepseek-chat). A *partial* LLM_*
# config is an error, not a fallback.
# DEEPSEEK_API_KEY=sk-your-deepseek-key

# Optional tuning
# LLM_TIMEOUT_MS=60000
# LLM_MAX_RETRIES=2
